{
  "name": "truth-md",
  "version": "2.4.0",
  "description": "WhatsApp Bot",
  "main": "index.js",
  "scripts": {
    "postinstall": "node -e \"const fs=require('fs');if(fs.existsSync('scripts/patch-baileys.js')){require('./scripts/patch-baileys.js')}else{console.log('patch-baileys.js not found, skipping')}\"",
    "start": "node server.js",
    "start:optimized": "node --max-old-space-size=512 --optimize-for-size --gc-interval=100 index.js",
    "start:heroku": "node server.js",
    "cleanup": "node cleanup.js",
    "reset-session": "node reset-session.js",
    "start:clean": "npm run cleanup && npm run start:optimized",
    "start:fresh": "npm run reset-session && npm start",
    "heroku-postbuild": "npm rebuild sharp && npm rebuild better-sqlite3",
    "install:panel": "npm install --omit=dev --no-audit --no-fund --legacy-peer-deps",
    "install:force": "npm install --omit=dev --force --no-audit --no-fund",
    "push": "node scripts/autopush.js",
    "autopush": "node scripts/autopush.js"
  },
  "keywords": [
    "whatsapp-bot"
  ],
  "author": "superstar",
  "license": "ISC",
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^7.0.0-rc12",
    "awesome-phonenumber": "^5.11.0",
    "axios": "^1.13.6",
    "better-sqlite3": "^12.8.0",
    "chalk": "^4.1.2",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.5",
    "fs-extra": "^11.3.4",
    "gtts": "^0.2.1",
    "jimp": "^1.6.0",
    "link-preview-js": "^3.2.0",
    "moment-timezone": "^0.5.48",
    "mumaker": "^2.0.0",
    "node-cache": "^5.1.2",
    "node-fetch": "^2.7.0",
    "node-id3": "^0.2.9",
    "node-webpmux": "^3.2.1",
    "node-youtube-music": "^0.8.3",
    "pg": "^8.20.0",
    "pino": "^9.6.0",
    "ruhend-scraper": "^8.3.0",
    "sharp": "^0.32.6",
    "webcrack": "^2.15.1",
    "ws": "^8.19.0",
    "yt-search": "^2.13.1",
    "ytdl-core": "^4.11.5",
    "socket.io": "^4.7.2"
  },
  "overrides": {
    "jimp": "^1.6.0"
  },
  "engines": {
    "node": "20.x"
  }
}
