# ── TRUTH-MD Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values before starting the bot.
#   cp .env.example .env

# ── WhatsApp Auth ────────────────────────────────────────────────────────────
# Option A: paste an existing session string (get one from truthsite.courtneytech.xyz)
SESSION_ID=

# ── Bot Owner ────────────────────────────────────────────────────────────────
# Your WhatsApp number with country code, no + sign (e.g. 254712345678)
OWNER_NUMBER=

# ── Server ───────────────────────────────────────────────────────────────────
# Port the bot's web UI and health endpoint listen on
PORT=5000

# ── Database (optional but recommended for persistent sessions) ──────────────
# PostgreSQL connection string — if blank, SQLite is used automatically
DATABASE_URL=

# ── Bot Customisation ────────────────────────────────────────────────────────
BOT_NAME=TRUTH-MD
PREFIX=.

# ── GitHub (required for .update and autopush commands) ─────────────────────
GITHUB_PERSONAL_ACCESS_TOKEN=

# ── Optional API Keys ────────────────────────────────────────────────────────
# GIF search commands
GIPHY_API_KEY=
